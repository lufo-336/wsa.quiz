<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Wsa.Quiz.App.MainView">

    <UserControl.Styles>
        <!-- Touch: nasconde la striscia di tab in alto del TabControl (la classe
             "touchnav" viene aggiunta in code-behind solo su TouchMode). Il
             TabControl resta il motore dei contenuti, ma la navigazione passa
             dalla barra inferiore. Desktop: nessuna classe → tab visibili. -->
        <Style Selector="TabControl.touchnav /template/ ItemsPresenter#PART_ItemsPresenter">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <!-- Pulsanti della bottom navigation (touch). -->
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="2,8"/>
            <!-- Altezza fissa della barra, indipendente da SzTapMin: la bottom
                 nav resta comoda anche se le altre dimensioni touch calano. -->
            <Setter Property="MinHeight" Value="54"/>
        </Style>
    </UserControl.Styles>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemAccentColorBrush}"
                Padding="20,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="WSA Quiz"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           x:Name="StatoHeaderText"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="White"
                           Opacity="0.85"/>
            </Grid>
        </Border>

        <!-- Footer diagnostico (desktop). Nascosto su touch in code-behind. -->
        <Border x:Name="FooterBar"
                DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource SystemBaseLowColor}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock x:Name="FooterText"
                       FontSize="11"
                       Foreground="{DynamicResource SystemBaseMediumColor}"/>
        </Border>

        <!-- Bottom navigation (touch). Nascosta su desktop; resa visibile e
             cablata a Tabs.SelectedIndex in code-behind quando TouchMode. -->
        <Border x:Name="BottomNav"
                DockPanel.Dock="Bottom"
                IsVisible="False"
                Background="{DynamicResource SystemChromeMediumColor}"
                BorderBrush="{DynamicResource SystemBaseLowColor}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,*,*,*">
                <Button x:Name="NavHome" Grid.Column="0" Classes="nav" Tag="0" Click="OnNavClick">
                    <TextBlock x:Name="NavHomeLabel" Text="Home"
                               FontSize="13" TextAlignment="Center"/>
                </Button>
                <Button x:Name="NavCronologia" Grid.Column="1" Classes="nav" Tag="1" Click="OnNavClick">
                    <TextBlock x:Name="NavCronologiaLabel" Text="Cronologia"
                               FontSize="13" TextAlignment="Center" TextWrapping="Wrap"/>
                </Button>
                <Button x:Name="NavSospesi" Grid.Column="2" Classes="nav" Tag="2" Click="OnNavClick">
                    <TextBlock x:Name="NavSospesiLabel" Text="Sospesi"
                               FontSize="13" TextAlignment="Center"/>
                </Button>
                <Button x:Name="NavStatistiche" Grid.Column="3" Classes="nav" Tag="3" Click="OnNavClick">
                    <TextBlock x:Name="NavStatisticheLabel" Text="Statistiche"
                               FontSize="13" TextAlignment="Center" TextWrapping="Wrap"/>
                </Button>
            </Grid>
        </Border>

        <!-- Errore globale (visibile solo se il caricamento dati fallisce) -->
        <Border x:Name="ErrorePanel"
                DockPanel.Dock="Top"
                Background="#F9E7E6"
                BorderBrush="#B85450"
                BorderThickness="0,0,0,1"
                Padding="16,12"
                IsVisible="False">
            <StackPanel Spacing="4">
                <TextBlock Text="Errore nel caricamento dei dati"
                           FontWeight="SemiBold"
                           Foreground="#8C3B38"/>
                <TextBlock x:Name="ErroreText"
                           FontSize="12"
                           Foreground="#8C3B38"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <TabControl x:Name="Tabs" Padding="0">
            <TabItem Header="Home">
                <ContentControl x:Name="HomeArea"/>
            </TabItem>
            <TabItem Header="Cronologia">
                <ContentControl x:Name="CronologiaArea"/>
            </TabItem>
            <TabItem Header="Sospesi">
                <ContentControl x:Name="SospesiArea"/>
            </TabItem>
            <TabItem Header="Statistiche">
                <ContentControl x:Name="StatisticheArea"/>
            </TabItem>
        </TabControl>

    </DockPanel>

</UserControl>
