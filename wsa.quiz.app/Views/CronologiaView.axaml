<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:state="using:Wsa.Quiz.App.State"
             xmlns:views="using:Wsa.Quiz.App.Views"
             mc:Ignorable="d"
             x:Class="Wsa.Quiz.App.Views.CronologiaView"
             x:DataType="views:CronologiaView">

    <DockPanel>

        <!-- ======================================== HEADER (titolo + aggiorna) -->
        <Grid DockPanel.Dock="Top"
              ColumnDefinitions="*,Auto,Auto"
              Margin="20,16,20,8">
            <StackPanel Spacing="2">
                <TextBlock Text="Cronologia"
                           FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Sottotitolo}"
                           FontSize="12"
                           Foreground="{DynamicResource SystemBaseMediumColor}"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Aggiorna"
                    Click="OnAggiornaClick"
                    Padding="14,6"
                    FontSize="12"
                    Margin="0,0,8,0"
                    ToolTip.Tip="Ricarica la cronologia dal disco. Utile se hai fatto un quiz dal console mentre l'app era aperta."/>

            <Button Grid.Column="2"
                    Content="Svuota cronologia"
                    Click="OnSvuotaCronologiaClick"
                    Classes="danger"
                    Padding="14,6"
                    FontSize="12"
                    IsEnabled="{Binding !NessunaSessione}"
                    ToolTip.Tip="Elimina TUTTE le sessioni dalla cronologia. Verra' chiesta conferma."/>
        </Grid>

        <!-- ======================================== LISTA + DETTAGLIO (swap) -->
        <Grid>
            <!-- LISTA -->
            <DockPanel IsVisible="{Binding !ModoDettaglio}">

                <!-- Stato vuoto -->
                <Border DockPanel.Dock="Top"
                        IsVisible="{Binding NessunaSessione}"
                        Margin="20,8,20,0"
                        Background="{DynamicResource SystemRegionBrush}"
                        BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="20">
                    <StackPanel HorizontalAlignment="Center" Spacing="6">
                        <TextBlock Text="Nessuna sessione registrata"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Avvia un quiz dalla Home per iniziare a costruire la tua cronologia."
                                   FontSize="12"
                                   Foreground="{DynamicResource SystemBaseMediumColor}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MaxWidth="420"/>
                    </StackPanel>
                </Border>

                <!-- Header colonne (visibile solo se la lista non e' vuota) -->
                <Border DockPanel.Dock="Top"
                        IsVisible="{Binding !NessunaSessione}"
                        Margin="20,8,20,0"
                        BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="0,0,0,1"
                        Padding="14,8">
                    <Grid ColumnDefinitions="Auto,180,*,90,90,90,160">
                        <TextBlock Text="" Width="6"/>
                        <TextBlock Grid.Column="1" Text="Data"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemBaseMediumColor}"/>
                        <TextBlock Grid.Column="2" Text="Modalita'"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemBaseMediumColor}"/>
                        <TextBlock Grid.Column="3" Text="%"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemBaseMediumColor}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="Risposte"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemBaseMediumColor}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="5" Text="Durata"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemBaseMediumColor}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="6" Text="" />
                    </Grid>
                </Border>

                <!-- Hint sul doppio-click -->
                <TextBlock DockPanel.Dock="Bottom"
                           IsVisible="{Binding !NessunaSessione}"
                           Text="Doppio click su una riga per vedere il dettaglio domanda per domanda."
                           FontSize="11"
                           Foreground="{DynamicResource SystemBaseMediumColor}"
                           Margin="20,4,20,12"/>

                <ScrollViewer Margin="20,0,20,0"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding !NessunaSessione}">
                    <ListBox x:Name="ListaSessioni"
                             ItemsSource="{Binding Sessioni}"
                             SelectionMode="Single"
                             DoubleTapped="OnSessioneDoubleTapped"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="state:RisultatoCronologiaItem">
                                <Grid ColumnDefinitions="6,180,*,90,90,90,160"
                                      Margin="0,2">
                                    <Border Grid.Column="0"
                                            Width="6"
                                            Background="{Binding ColorePercentuale}"
                                            CornerRadius="3"/>

                                    <StackPanel Grid.Column="1" Spacing="2" Margin="8,2,4,2">
                                        <TextBlock Text="{Binding DataFormattata}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Abbandonato"
                                                   FontSize="10"
                                                   Foreground="#B85450"
                                                   IsVisible="{Binding Abbandonato}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Modalita}"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding MateriaEtichetta}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SystemBaseMediumColor}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding PercentualeFormattata}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{Binding ColorePercentuale}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="4"
                                               Text="{Binding Conteggio}"
                                               FontSize="12"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="5"
                                               Text="{Binding DurataFormattata}"
                                               FontSize="12"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>

                                    <!-- Bottoni: stato normale.
                                         IsTabStop=False perche' altrimenti il Tab entrerebbe
                                         dentro i bottoni della riga al posto di restare sul
                                         ListBoxItem: cosi' frecce e Invio funzionano come
                                         si aspetta l'utente sulla riga selezionata. Il
                                         click di mouse continua a funzionare; per eliminare
                                         da tastiera c'e' il tasto Canc. -->
                                    <StackPanel Grid.Column="6"
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="8,0,0,0"
                                                IsVisible="{Binding NonInAttesaConferma}">
                                        <Button Content="Elimina"
                                                Click="OnEliminaClick"
                                                IsTabStop="False"
                                                Classes="danger"
                                                Padding="12,4"
                                                FontSize="11"/>
                                    </StackPanel>

                                    <!-- Bottoni: stato conferma -->
                                    <StackPanel Grid.Column="6"
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="8,0,0,0"
                                                IsVisible="{Binding InAttesaConfermaEliminazione}">
                                        <Button Content="Si', elimina"
                                                Click="OnConfermaEliminaClick"
                                                IsTabStop="False"
                                                Classes="danger"
                                                Padding="10,4"
                                                FontSize="11"/>
                                        <Button Content="Annulla"
                                                Click="OnAnnullaEliminaClick"
                                                IsTabStop="False"
                                                Padding="10,4"
                                                FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </DockPanel>

            <!-- DETTAGLIO -->
            <ContentControl x:Name="DettaglioArea"
                            IsVisible="{Binding ModoDettaglio}"/>
        </Grid>

    </DockPanel>

</UserControl>
