<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:state="using:Wsa.Quiz.App.State"
             xmlns:views="using:Wsa.Quiz.App.Views"
             mc:Ignorable="d"
             x:Class="Wsa.Quiz.App.Views.CronologiaDettaglioView"
             x:DataType="views:CronologiaDettaglioView">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="20">

        <!-- TOP BAR (indietro + titolo) -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,12">
            <Button Content="&#x2190;  Cronologia"
                    Click="OnIndietroClick"
                    Padding="12,6"
                    FontSize="12"
                    ToolTip.Tip="Torna alla lista delle sessioni."/>
            <StackPanel Grid.Column="1" Spacing="2" Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Titolo}"
                           FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Sottotitolo}"
                           FontSize="12"
                           Foreground="{DynamicResource SystemBaseMediumColor}"/>
            </StackPanel>
        </Grid>

        <!-- STATISTICHE (stesso pattern di RiepilogoView) -->
        <Border Grid.Row="1"
                Background="{DynamicResource SystemRegionBrush}"
                BorderBrush="{DynamicResource SystemBaseLowColor}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="20"
                Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,*,*,*,*" RowDefinitions="Auto,Auto">
                <StackPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Spacing="2">
                    <TextBlock Text="{Binding PercentualeFormattata}"
                               FontSize="34" FontWeight="Bold"
                               Foreground="{Binding ColorePercentuale}"/>
                    <TextBlock Text="corrette"
                               FontSize="11"
                               Foreground="{DynamicResource SystemBaseMediumColor}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="0" Spacing="2">
                    <TextBlock Text="Totale"
                               FontSize="11"
                               Foreground="{DynamicResource SystemBaseMediumColor}"/>
                    <TextBlock Text="{Binding TotaleDomande}"
                               FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Grid.Row="0" Spacing="2">
                    <TextBlock Text="Corrette"
                               FontSize="11"
                               Foreground="{DynamicResource SystemBaseMediumColor}"/>
                    <TextBlock Text="{Binding RisposteCorrette}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#1F7A4D"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Grid.Row="0" Spacing="2">
                    <TextBlock Text="Errate"
                               FontSize="11"
                               Foreground="{DynamicResource SystemBaseMediumColor}"/>
                    <TextBlock Text="{Binding RisposteErrate}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#B85450"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Grid.Row="0" Spacing="2">
                    <TextBlock Text="Punteggio"
                               FontSize="11"
                               Foreground="{DynamicResource SystemBaseMediumColor}"/>
                    <TextBlock Text="{Binding Punteggio}"
                               FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="4"
                            Orientation="Horizontal" Spacing="20" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Durata:"
                                   FontSize="12"
                                   Foreground="{DynamicResource SystemBaseMediumColor}"/>
                        <TextBlock Text="{Binding DurataFormattata}"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Modalita':"
                                   FontSize="12"
                                   Foreground="{DynamicResource SystemBaseMediumColor}"/>
                        <TextBlock Text="{Binding Modalita}"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Materia:"
                                   FontSize="12"
                                   Foreground="{DynamicResource SystemBaseMediumColor}"/>
                        <TextBlock Text="{Binding MateriaEtichetta}"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LISTA DETTAGLI (stesso template di RiepilogoView, ma con colore dal flag Corretta) -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <TextBlock Text="{Binding TitoloLista}"
                           FontWeight="SemiBold"
                           FontSize="14"/>

                <TextBlock Text="Nessuna risposta registrata in questa sessione."
                           IsVisible="{Binding NessunDettaglio}"
                           Foreground="{DynamicResource SystemBaseMediumColor}"
                           FontStyle="Italic"/>

                <ItemsControl ItemsSource="{Binding Dettagli}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="state:DettaglioRispostaItem">
                            <Border Background="{DynamicResource SystemRegionBrush}"
                                    BorderBrush="{Binding ColoreBordo}"
                                    BorderThickness="2"
                                    CornerRadius="6"
                                    Padding="14,10"
                                    Margin="0,0,0,6">
                                <StackPanel Spacing="4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock FontSize="11"
                                                   Foreground="{DynamicResource SystemBaseMediumColor}">
                                            <Run Text="{Binding MateriaNome}"/>
                                            <Run Text="·"/>
                                            <Run Text="{Binding Categoria}"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding EsitoEtichetta}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding ColoreEsito}"/>
                                    </Grid>

                                    <TextBlock Text="{Binding TestoDomanda}"
                                               TextWrapping="Wrap"
                                               FontWeight="SemiBold"/>

                                    <Grid ColumnDefinitions="Auto,*" Margin="0,4,0,0">
                                        <TextBlock Text="Tu hai risposto:"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SystemBaseMediumColor}"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding RispostaData}"
                                                   FontSize="12"
                                                   Foreground="{Binding ColoreRisposta}"
                                                   TextWrapping="Wrap"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*"
                                          IsVisible="{Binding MostraRispostaCorretta}">
                                        <TextBlock Text="Corretta:"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SystemBaseMediumColor}"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding RispostaCorretta}"
                                                   FontSize="12"
                                                   Foreground="#1F7A4D"
                                                   TextWrapping="Wrap"/>
                                    </Grid>

                                    <TextBlock Text="{Binding TentativiEtichetta}"
                                               IsVisible="{Binding MostraTentativi}"
                                               FontSize="11"
                                               FontStyle="Italic"
                                               Foreground="{DynamicResource SystemBaseMediumColor}"/>

                                    <TextBlock Text="{Binding Spiegazione}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"
                                               IsVisible="{Binding Spiegazione, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Foreground="{DynamicResource SystemBaseMediumHighColor}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- BARRA IN BASSO -->
        <Grid Grid.Row="3"
              ColumnDefinitions="Auto,Auto,*,Auto"
              Margin="0,16,0,0">

            <!-- Stato normale -->
            <Button Grid.Column="0"
                    Content="Elimina questa partita"
                    Click="OnEliminaClick"
                    Classes="danger"
                    Padding="14,8"
                    FontSize="12"
                    IsVisible="{Binding NonInAttesaConferma}"/>

            <!-- Stato conferma -->
            <StackPanel Grid.Column="0" Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center"
                        IsVisible="{Binding InAttesaConfermaEliminazione}">
                <TextBlock Text="Sicuro?"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#B85450"
                           FontWeight="SemiBold"
                           Margin="0,0,4,0"/>
                <Button Content="Si', elimina"
                        Click="OnConfermaEliminaClick"
                        Classes="danger"
                        Padding="14,6"
                        FontSize="12"/>
                <Button Content="Annulla"
                        Click="OnAnnullaEliminaClick"
                        Padding="14,6"
                        FontSize="12"/>
            </StackPanel>

            <Button Grid.Column="3"
                    Content="Torna alla cronologia"
                    Click="OnIndietroClick"
                    Classes="accent"
                    Padding="22,10"
                    FontSize="14"
                    FontWeight="SemiBold"/>
        </Grid>

    </Grid>

</UserControl>
