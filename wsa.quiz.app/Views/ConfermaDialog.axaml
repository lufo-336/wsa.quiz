<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Wsa.Quiz.App.Views.ConfermaDialog">

  <UserControl.Styles>
    <!-- Accent con blu esplicito: SystemAccentColorBrush non rende affidabile
         nell'overlay (vedi PausaDialog). -->
    <Style Selector="Button.accent /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#2D6FB8"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#2D6FB8"/>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#3A7FCC"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#3A7FCC"/>
    </Style>
  </UserControl.Styles>

  <!-- Card del dialogo (overlay in-page, M3). Forzo Light sul sottoalbero così i
       Button default restano leggibili anche con app in tema scuro (vedi PausaDialog). -->
  <ThemeVariantScope RequestedThemeVariant="Light">
  <Border Background="#FAFAFA"
          BorderBrush="#D6D6D6"
          BorderThickness="1"
          CornerRadius="8"
          Padding="20"
          MinWidth="340"
          MaxWidth="460">
    <StackPanel Spacing="14">
      <TextBlock x:Name="MessaggioText"
                 FontSize="14"
                 FontWeight="SemiBold"
                 Foreground="#1F1F1F"/>
      <TextBlock x:Name="DettaglioText"
                 FontSize="12"
                 TextWrapping="Wrap"
                 Foreground="#5A5A5A"/>
      <StackPanel Orientation="Horizontal"
                  Spacing="8"
                  HorizontalAlignment="Right">
        <Button x:Name="AnnullaBtn"
                Content="Annulla"
                Padding="14,8"
                Click="OnAnnullaClick"/>
        <Button x:Name="ConfermaBtn"
                Padding="14,8"
                Click="OnConfermaClick"/>
      </StackPanel>
    </StackPanel>
  </Border>
  </ThemeVariantScope>

</UserControl>
