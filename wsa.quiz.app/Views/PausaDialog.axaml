<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Wsa.Quiz.App.Views.PausaDialog"
        Title="Quiz in pausa"
        Width="480" Height="210"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

  <StackPanel Margin="20" Spacing="12">
    <TextBlock Text="Quiz in pausa. Cosa vuoi fare?"
               FontSize="14"
               FontWeight="SemiBold"/>
    <TextBlock Text="Annulla riprende il quiz. Abbandona lo chiude e lo registra in cronologia come abbandonato. Salva e esci lo mette nei Sospesi: lo riprenderai dalla relativa tab."
               FontSize="12"
               TextWrapping="Wrap"
               Foreground="{DynamicResource SystemBaseMediumColor}"/>

    <!-- Pulsantiera: Abbandona (sx, danger) | spazio | Annulla, Salva e esci (dx, accent) -->
    <Grid ColumnDefinitions="Auto,*,Auto"
          Margin="0,4,0,0">
      <Button x:Name="AbbandonaBtn"
              Content="Abbandona"
              Padding="14,5"
              Classes="danger"
              Grid.Column="0"
              Click="OnAbbandonaClick"/>
      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button x:Name="AnnullaBtn"
                Content="Annulla"
                Padding="14,5"
                Click="OnAnnullaClick"/>
        <Button x:Name="SalvaBtn"
                Content="Salva e esci"
                Padding="14,5"
                Classes="accent"
                Click="OnSalvaClick"/>
      </StackPanel>
    </Grid>
  </StackPanel>

</Window>
