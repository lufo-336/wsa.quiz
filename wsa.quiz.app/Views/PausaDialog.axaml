<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Wsa.Quiz.App.Views.PausaDialog">

  <UserControl.Styles>
    <!-- L'accent via SystemAccentColorBrush non rende in modo affidabile dentro
         l'overlay (sfondo trasparente → testo bianco illeggibile sulla card chiara).
         Forzo un blu esplicito, stesso approccio dei bottoni danger (hex). -->
    <Style Selector="Button.accent /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#2D6FB8"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#2D6FB8"/>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#3A7FCC"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#3A7FCC"/>
    </Style>
  </UserControl.Styles>

  <!-- Card del dialogo (overlay in-page, M3). Sfondo chiaro hardcoded; forzo il
       sottoalbero a tema Light così i Button default (es. "Annulla") restano
       leggibili anche quando l'app gira in tema scuro (altrimenti testo chiaro
       su card chiara). Il tema scuro vero della card è rinviato a Step 10. -->
  <ThemeVariantScope RequestedThemeVariant="Light">
  <Border Background="#FAFAFA"
          BorderBrush="#D6D6D6"
          BorderThickness="1"
          CornerRadius="8"
          Padding="20"
          MinWidth="360"
          MaxWidth="480">
    <StackPanel Spacing="12">
      <TextBlock Text="Quiz in pausa. Cosa vuoi fare?"
                 FontSize="14"
                 FontWeight="SemiBold"
                 Foreground="#1F1F1F"/>
      <TextBlock Text="Annulla riprende il quiz. Abbandona lo chiude e lo registra in cronologia come abbandonato. Salva e esci lo mette nei Sospesi: lo riprenderai dalla relativa tab."
                 FontSize="12"
                 TextWrapping="Wrap"
                 Foreground="#5A5A5A"/>

      <!-- Pulsantiera: Abbandona (sx, danger) | spazio | Annulla, Salva e esci (dx, accent) -->
      <Grid ColumnDefinitions="Auto,*,Auto"
            Margin="0,4,0,0">
        <Button x:Name="AbbandonaBtn"
                Content="Abbandona"
                Padding="14,8"
                Classes="danger"
                Grid.Column="0"
                Click="OnAbbandonaClick"/>
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8">
          <Button x:Name="AnnullaBtn"
                  Content="Annulla"
                  Padding="14,8"
                  Click="OnAnnullaClick"/>
          <Button x:Name="SalvaBtn"
                  Content="Salva e esci"
                  Padding="14,8"
                  Classes="accent"
                  Click="OnSalvaClick"/>
        </StackPanel>
      </Grid>
    </StackPanel>
  </Border>
  </ThemeVariantScope>

</UserControl>
